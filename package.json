{
  "name": "widgetfarm",
  "version": "0.0.27",
  "type": "module",
  "main": "./dist/widgetfarm.umd.js",
  "module": "./dist/widgetfarm.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/widgetfarm.es.js",
      "require": "./dist/widgetfarm.umd.js"
    },
    "./styles/*": "./dist/styles/*"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run clean && tsc --project tsconfig.build.json && vite build && npm run copy-styles",
    "build-storybook": "storybook build",
    "clean": "node scripts/clean.js",
    "copy-styles": "node scripts/copy-styles.js",
    "dev": "vite",
    "lint": "eslint .",
    "prebuild": "npm run typia:generate",
    "prepack": "npm run build",
    "prestorybook": "npm run typia:generate",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "typia:generate": "typia generate --input ./typia --output ./src/_generated --project ./tsconfig.build.json"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.1",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^6",
    "change-case": "^5.4.4",
    "cli-table3": "^0.6.5",
    "clsx": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "storybook": "^10.3.5",
    "ts-patch": "^3.3.0",
    "typescript": "^6",
    "typescript-eslint": "^8.59.0",
    "vite": "^8"
  },
  "dependencies": {
    "@ark-ui/react": "^5.36.2",
    "@ctrl/tinycolor": "^4.2.0",
    "@zag-js/checkbox": "^1.40.0",
    "@zag-js/clipboard": "^1.40.0",
    "@zag-js/dialog": "^1.40.0",
    "@zag-js/file-upload": "^1.40.0",
    "@zag-js/number-input": "^1.40.0",
    "@zag-js/react": "^1.40.0",
    "react-icons": "^5.6.0",
    "typia": "^12.1.0-dev.20260325"
  }
}
